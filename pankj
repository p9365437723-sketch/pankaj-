                  </div>
                  <div>
                    <label className="block text-slate-300 font-bold mb-2">3 Mark Questions (comma separated)</label>
                    <textarea
                      placeholder="Q1, Q2, Q3"
                      value={(formData.threeMarkQuestions || []).join(', ')}
                      onChange={(e) => setFormData({ ...formData, threeMarkQuestions: e.target.value.split(',').map(q => q.trim()) })}
                      rows="3"
                      className="w-full bg-slate-700/50 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-red-400"
                    />
                  </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                  <div>
                    <label className="block text-slate-300 font-bold mb-2">5 Mark Questions (comma separated)</label>
                    <textarea
                      placeholder="Q1, Q2, Q3"
                      value={(formData.fiveMarkQuestions || []).join(', ')}
                      onChange={(e) => setFormData({ ...formData, fiveMarkQuestions: e.target.value.split(',').map(q => q.trim()) })}
                      rows="3"
                      className="w-full bg-slate-700/50 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-red-400"
                    />
                  </div>
                  <div>
                    <label className="block text-slate-300 font-bold mb-2">Key Terms (JSON format)</label>
                    <textarea
                      placeholder='{"term": "definition"}'
                      value={typeof formData.keyTerms === 'object' ? JSON.stringify(formData.keyTerms || {}) : (formData.keyTerms || '{}')}
                      onChange={(e) => {
                        try {
                          setFormData({ ...formData, keyTerms: JSON.parse(e.target.value) });
                        } catch {
                          setFormData({ ...formData, keyTerms: e.target.value });
                        }
                      }}
                      rows="3"
                      className="w-full bg-slate-700/50 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-red-400"
                    />
                  </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                  <div>
                    <label className="block text-slate-300 font-bold mb-2">Key People (JSON format)</label>
                    <textarea
                      placeholder='{"person": "details"}'
                      value={typeof formData.keyPeople === 'object' ? JSON.stringify(formData.keyPeople || {}) : (formData.keyPeople || '{}')}
                      onChange={(e) => {
                        try {
                          setFormData({ ...formData, keyPeople: JSON.parse(e.target.value) });
                        } catch {
                          setFormData({ ...formData, keyPeople: e.target.value });
                        }
                      }}
                      rows="3"
                      className="w-full bg-slate-700/50 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-red-400"
                    />
                  </div>
                  <div>
                    <label className="block text-slate-300 font-bold mb-2">Timeline (JSON format)</label>
                    <textarea
                      placeholder='[{"year": "2020", "event": "description"}]'
                      value={Array.isArray(formData.timeline) ? JSON.stringify(formData.timeline || []) : (formData.timeline || '[]')}
                      onChange={(e) => {
                        try {
                          setFormData({ ...formData, timeline: JSON.parse(e.target.value) });
                        } catch {
                          setFormData({ ...formData, timeline: e.target.value });
                        }
                      }}
                      rows="3"
                      className="w-full bg-slate-700/50 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-red-400"
                    />
                  </div>
                </div>

                <div>
                  <label className="block text-slate-300 font-bold mb-2">Quiz (JSON format)</label>
                  <textarea
                    placeholder='[{"question": "Q1?", "options": ["A", "B", "C", "D"], "correctAnswer": 0}]'
                    value={Array.isArray(formData.quiz) ? JSON.stringify(formData.quiz || []) : (formData.quiz || '[]')}
                    onChange={(e) => {
                      try {
                        setFormData({ ...formData, quiz: JSON.parse(e.target.value) });
                      } catch {
                        setFormData({ ...formData, quiz: e.target.value });
                      }
                    }}
                    rows="6"
                    className="w-full bg-slate-700/50 border border-slate-600 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-red-400 mb-6"
                  />
                </div>

                <div className="flex gap-4">
                  <button
                    onClick={handleSaveChapter}
                    disabled={loading}
                    className="flex-1 bg-gradient-to-r from-emerald-600 to-emerald-700 hover:from-emerald-700 hover:to-emerald-800 text-white font-bold py-3 rounded-lg transition disabled:opacity-50"
                  >
                    {loading ? 'Saving...' : (editingId ? '✓ Update Chapter' : '+ Save Chapter')}
                  </button>
                  <button
                    onClick={() => {
                      setShowAddForm(false);
                      setFormData({});
                      setEditingId(null);
                    }}
                    className="flex-1 bg-slate-700 hover:bg-slate-600 text-white font-bold py-3 rounded-lg transition"
                  >
                    Cancel
                  </button>
                </div>
              </div>
            )}

            {/* Chapters List */}
            {selectedSubject && (
              <div>
                <h3 className="text-xl font-bold text-white mb-4">
                  📖 Chapters - {subjects.find(s => s.id === selectedSubject)?.name || selectedSubject}
                </h3>

                {chapters.length === 0 ? (
                  <div className="bg-slate-800/50 border border-slate-700 rounded-xl p-12 text-center text-slate-400">
                    No chapters found. Add one to get started!
                  </div>
                ) : (
                  <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {chapters.map((chapter) => (
                      <div key={chapter.id} className="bg-slate-800/50 border border-slate-700 rounded-lg p-6 hover:border-red-400/50 transition">
                        <h4 className="text-white font-bold mb-2">{chapter.title}</h4>
                        <p className="text-slate-400 text-sm mb-4">Chapter {chapter.chapterNumber}</p>
                        <div className="flex gap-2">
                          <button
                            onClick={() => startEditChapter(chapter)}
                            className="flex-1 bg-blue-600 hover:bg-blue-700 text-white px-3 py-2 rounded text-sm font-bold transition"
                          >
                            Edit
                          </button>
                          <button
                            onClick={() => deleteChapter(chapter.id)}
                            className="flex-1 bg-red-600 hover:bg-red-700 text-white px-3 py-2 rounded text-sm font-bold transition"
                          >
                            Delete
                          </button>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )}
          </div>
        )}
      </div>

      {/* Footer */}
      <div className="bg-slate-800/50 border-t border-slate-700 mt-20">
        <div className="max-w-7xl mx-auto px-6 py-8 text-center text-slate-400 text-sm">
          © 2026 Pankaj Digital Academy. Built for SEBA Excellence.
        </div>
      </div>
    </div>
  );
}
