                                    type="radio"
                                    name={`q${qIdx}`}
                                    value={oIdx}
                                    checked={quizAnswers[qIdx] == oIdx}
                                    onChange={() => !quizSubmitted && setQuizAnswers({ ...quizAnswers, [qIdx]: oIdx })}
                                    disabled={quizSubmitted}
                                    className="w-4 h-4 text-emerald-400"
                                  />
                                  <span className={`text-slate-300 group-hover:text-slate-200 transition ${
                                    quizSubmitted && oIdx === question.correctAnswer ? 'text-green-300 font-bold' : ''
                                  } ${
                                    quizSubmitted && quizAnswers[qIdx] == oIdx && oIdx !== question.correctAnswer ? 'text-red-300 font-bold' : ''
                                  }`}>
                                    {option}
                                  </span>
                                </label>
                              ))}
                            </div>
                          </div>
                        ))}

                        {!quizSubmitted && (
                          <button
                            onClick={handleQuizSubmit}
                            className="w-full bg-gradient-to-r from-emerald-500 to-emerald-600 hover:from-emerald-600 hover:to-emerald-700 text-white font-bold py-4 rounded-xl transition"
                          >
