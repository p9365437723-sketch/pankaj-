                              {quizScore} / {chapterContent.quiz.length}
                            </p>
                            <p className="text-blue-300">
                              Score: {Math.round((quizScore / chapterContent.quiz.length) * 100)}%
                            </p>
                          </div>
                        )}
                      </div>
                    ) : (
                      <p className="text-slate-400">No quiz available for this chapter.</p>
                    )}
                  </div>
                )}
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Footer */}
      <div className="bg-slate-800/50 border-t border-emerald-400/20 mt-20">
        <div className="max-w-7xl mx-auto px-6 py-8 text-center text-slate-400 text-sm">
          © 2026 Pankaj Digital Academy. Built for SEBA Excellence.
        </div>
      </div>
    </div>
  );
}

// ===== ADMIN DASHBOARD =====
function AdminDashboard({ user }) {
  const [activeSection, setActiveSection] = useState('dashboard');
  const [users, setUsers] = useState([]);
  const [classes, setClasses] = useState([]);
  const [subjects, setSubjects] = useState([]);
  const [chapters, setChapters] = useState([]);
  const [selectedClass, setSelectedClass] = useState('');
  const [selectedSubject, setSelectedSubject] = useState('');
  const [showAddForm, setShowAddForm] = useState(false);
  const [formData, setFormData] = useState({});
  const [loading, setLoading] = useState(false);
  const [searchTerm, setSearchTerm] = useState('');
  const [editingId, setEditingId] = useState(null);

  // Load users
  useEffect(() => {
    const unsubscribe = onSnapshot(collection(db, 'users'), (snapshot) => {
      setUsers(snapshot.docs
        .map(doc => ({ id: doc.id, ...doc.data() }))
        .filter(u => u.role === 'student')
      );
    });
    return () => unsubscribe();
  }, []);

  // Load classes
  useEffect(() => {
    const unsubscribe = onSnapshot(collection(db, 'classes'), (snapshot) => {
      setClasses(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() })));
    });
    return () => unsubscribe();
  }, []);

  // Load subjects
  useEffect(() => {
    if (selectedClass) {
      const q = query(collection(db, 'subjects'), where('classId', '==', selectedClass));
      const unsubscribe = onSnapshot(q, (snapshot) => {
        setSubjects(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() })));
      });
      return () => unsubscribe();
    }
  }, [selectedClass]);

  // Load chapters
  useEffect(() => {
    if (selectedSubject) {
      const q = query(collection(db, 'chapters'), where('subjectId', '==', selectedSubject));
      const unsubscribe = onSnapshot(q, (snapshot) => {
        setChapters(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() })));
      });
      return () => unsubscribe();
    }
  }, [selectedSubject]);

  // Block/Unblock user
  const toggleBlockUser = async (userId, currentStatus) => {
    try {
      await updateDoc(doc(db, 'users', userId), {
        isBlocked: !currentStatus
      });
      alert(currentStatus ? 'User unblocked' : 'User blocked');
    } catch (err) {
      alert('Error: ' + err.message);
    }
  };

  // Delete user
  const deleteUser = async (userId) => {
    if (window.confirm('Are you sure? This action cannot be undone.')) {
      try {
        await deleteDoc(doc(db, 'users', userId));
        alert('User deleted');
      } catch (err) {
        alert('Error: ' + err.message);
      }
    }
  };

  // Add/Update chapter
  const handleSaveChapter = async () => {
    if (!formData.title || !selectedSubject) {
      alert('Please fill all required fields');
      return;
    }

    setLoading(true);
    try {
      const chapterData = {
        ...formData,
        subjectId: selectedSubject,
        class: selectedClass,
        subject: subjects.find(s => s.id === selectedSubject)?.name,
        updatedAt: new Date()
      };

      if (editingId) {
        await updateDoc(doc(db, 'chapters', editingId), chapterData);
        alert('Chapter updated successfully');
      } else {
        await addDoc(collection(db, 'chapters'), chapterData);
        alert('Chapter added successfully');
      }

      setFormData({});
      setShowAddForm(false);
      setEditingId(null);
    } catch (err) {
      alert('Error: ' + err.message);
    } finally {
      setLoading(false);
    }
  };

  // Delete chapter
  const deleteChapter = async (chapterId) => {
    if (window.confirm('Are you sure? This action cannot be undone.')) {
      try {
        await deleteDoc(doc(db, 'chapters', chapterId));
        alert('Chapter deleted');
      } catch (err) {
        alert('Error: ' + err.message);
      }
    }
  };

  // Start editing chapter
  const startEditChapter = (chapter) => {
    setFormData(chapter);
    setEditingId(chapter.id);
    setShowAddForm(true);
  };

  const handleLogout = () => {
    localStorage.removeItem('adminSession');
    window.location.reload();
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-900 via-slate-900 to-slate-900">
      {/* Header */}
      <div className="bg-slate-800/80 backdrop-blur-xl border-b border-red-400/20 sticky top-0 z-50">
        <div className="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <span className="text-3xl">⚙️</span>
            <h1 className="text-2xl font-black text-red-400">Admin Dashboard</h1>
          </div>
          <button
            onClick={handleLogout}
            className="bg-red-600/80 hover:bg-red-700 text-white px-6 py-2 rounded-lg font-bold transition"
          >
            Logout
          </button>
        </div>
      </div>

      <div className="max-w-7xl mx-auto px-6 py-8">
