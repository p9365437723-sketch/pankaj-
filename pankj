// ===== STUDENT DASHBOARD =====
function StudentDashboard({ user }) {
  const [step, setStep] = useState(1); // 1: Class, 2: Subject, 3: Chapter
  const [selectedClass, setSelectedClass] = useState(null);
  const [selectedSubject, setSelectedSubject] = useState(null);
  const [selectedChapter, setSelectedChapter] = useState(null);
  const [showChapter, setShowChapter] = useState(false);
  const [subjects, setSubjects] = useState([]);
  const [chapters, setChapters] = useState([]);
  const [chapterContent, setChapterContent] = useState(null);
  const [activeTab, setActiveTab] = useState('notes');
  const [quizAnswers, setQuizAnswers] = useState({});
  const [quizSubmitted, setQuizSubmitted] = useState(false);
  const [quizScore, setQuizScore] = useState(0);

  const classes = [
    { id: '9', name: 'Class 9', icon: '📚' },
    { id: '10', name: 'Class 10', icon: '📖' }
  ];

  const subjectsByClass = {
    '9': ['English', 'Hindi', 'Science', 'Social Science'],
    '10': ['English', 'Hindi', 'Science', 'Social Science']
  };

  // Load subjects when class is selected
  useEffect(() => {
    if (selectedClass) {
      setSubjects(subjectsByClass[selectedClass] || []);
      setStep(2);
    }
  }, [selectedClass]);

  // Load chapters from Firestore
  useEffect(() => {
    if (selectedSubject && selectedClass) {
      const q = query(
        collection(db, 'chapters'),
        where('class', '==', selectedClass),
        where('subject', '==', selectedSubject)
      );

      const unsubscribe = onSnapshot(q, (snapshot) => {
        setChapters(snapshot.docs.map(doc => ({
          id: doc.id,
          ...doc.data()
        })));
      });

      setStep(3);
      return () => unsubscribe();
    }
  }, [selectedSubject, selectedClass]);

  // Load chapter content
  const loadChapterContent = async (chapterId) => {
    try {
      const chapterRef = doc(db, 'chapters', chapterId);
      const chapterSnap = await getDoc(chapterRef);
      
      if (chapterSnap.exists()) {
        setChapterContent({
          id: chapterId,
          ...chapterSnap.data()
        });
        setSelectedChapter(chapterId);
        setShowChapter(true);
        setActiveTab('notes');
        setQuizAnswers({});
        setQuizSubmitted(false);
        setQuizScore(0);
      }
    } catch (err) {
      console.error('Error loading chapter:', err);
    }
  };

  // Handle quiz submission
  const handleQuizSubmit = () => {
    if (!chapterContent?.quiz) return;

    let score = 0;
    const quiz = chapterContent.quiz;

    Object.keys(quizAnswers).forEach((qIndex) => {
      const qIdx = parseInt(qIndex);
      if (quiz[qIdx] && quiz[qIdx].correctAnswer === quizAnswers[qIdx]) {
        score++;
      }
    });

    setQuizScore(score);
    setQuizSubmitted(true);
  };

  const handleLogout = async () => {
    await signOut(auth);
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-slate-900 via-emerald-900 to-slate-900">
      {/* Header */}
      <div className="bg-slate-800/50 backdrop-blur-xl border-b border-emerald-400/20 sticky top-0 z-50">
        <div className="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <span className="text-3xl">🎓</span>
            <div>
              <h1 className="text-xl font-black text-transparent bg-clip-text bg-gradient-to-r from-emerald-300 to-blue-300">
                Pankaj Sir Study Hub
              </h1>
              <p className="text-xs text-emerald-300">{user?.email}</p>
            </div>
          </div>
          <button
            onClick={handleLogout}
            className="bg-red-600/80 hover:bg-red-700 text-white px-6 py-2 rounded-lg font-bold transition"
          >
            Logout
          </button>
        </div>
      </div>

      <div className="max-w-7xl mx-auto px-6 py-12">
        {!showChapter ? (
          <>
            {/* Step 1: Choose Class */}
            {step === 1 && (
              <div className="mb-12">
                <h2 className="text-3xl font-bold text-white mb-8">📚 Choose Your Class</h2>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                  {classes.map((cls) => (
                    <button
                      key={cls.id}
                      onClick={() => setSelectedClass(cls.id)}
                      className="group bg-gradient-to-br from-emerald-500/20 to-blue-500/20 hover:from-emerald-500/40 hover:to-blue-500/40 border border-emerald-400/40 rounded-2xl p-8 transition transform hover:scale-105 hover:shadow-2xl"
                    >
                      <div className="text-6xl mb-4">{cls.icon}</div>
                      <h3 className="text-2xl font-bold text-white">{cls.name}</h3>
                      <p className="text-emerald-300 mt-2">Start learning today</p>
                    </button>
                  ))}
                </div>
              </div>
            )}

            {/* Step 2: Choose Subject */}
            {step === 2 && (
              <div className="mb-12">
                <button
                  onClick={() => {
                    setStep(1);
                    setSelectedClass(null);
                    setSelectedSubject(null);
                  }}
                  className="mb-6 text-emerald-300 hover:text-emerald-200 flex items-center gap-2 font-bold"
                >
                  ← Back to Classes
                </button>
                <h2 className="text-3xl font-bold text-white mb-8">📖 Choose Your Subject</h2>
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                  {subjects.map((subject) => (
                    <button
                      key={subject}
                      onClick={() => setSelectedSubject(subject)}
                      className="bg-gradient-to-br from-emerald-500/20 to-blue-500/20 hover:from-emerald-500/40 hover:to-blue-500/40 border border-emerald-400/40 rounded-xl p-6 transition transform hover:scale-105 text-center"
                    >
                      <p className="text-white font-bold">{subject}</p>
                    </button>
                  ))}
                </div>
              </div>
            )}

            {/* Step 3: Choose Chapter */}
            {step === 3 && (
              <div className="mb-12">
                <button
                  onClick={() => {
                    setStep(2);
                    setSelectedSubject(null);
                    setChapters([]);
                  }}
                  className="mb-6 text-emerald-300 hover:text-emerald-200 flex items-center gap-2 font-bold"
                >
                  ← Back to Subjects
                </button>
                <h2 className="text-3xl font-bold text-white mb-8">📚 Choose Chapter - {selectedSubject}</h2>
                
                {chapters.length === 0 ? (
                  <div className="bg-slate-800/50 border border-emerald-400/20 rounded-2xl p-12 text-center">
                    <p className="text-slate-400 text-lg">No chapters available yet for this subject.</p>
                  </div>
                ) : (
                  <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {chapters.map((chapter) => (
                      <button
                        key={chapter.id}
                        onClick={() => loadChapterContent(chapter.id)}
                        className="group bg-gradient-to-br from-emerald-500/20 to-blue-500/20 hover:from-emerald-500/40 hover:to-blue-500/40 border border-emerald-400/40 hover:border-emerald-400/80 rounded-xl p-6 transition transform hover:scale-105 text-left hover:shadow-2xl"
                      >
                        <h3 className="text-lg font-bold text-white mb-2">{chapter.title}</h3>
                        <p className="text-emerald-300 text-sm">Chapter {chapter.chapterNumber}</p>
                        <div className="mt-4 flex gap-2 flex-wrap">
                          <span className="text-xs bg-emerald-500/20 text-emerald-300 px-2 py-1 rounded">📝 Notes</span>
                          <span className="text-xs bg-blue-500/20 text-blue-300 px-2 py-1 rounded">❓ Quiz</span>
                        </div>
                      </button>
                    ))}
                  </div>
                )}
              </div>
            )}
          </>
        ) : (
          // Chapter View
          <div>
            <button
              onClick={() => {
                setShowChapter(false);
                setStep(3);
              }}
              className="mb-6 text-emerald-300 hover:text-emerald-200 flex items-center gap-2 font-bold"
            >
              ← Back to Chapters
            </button>

            <div className="bg-slate-800/50 backdrop-blur-xl border border-emerald-400/20 rounded-2xl overflow-hidden shadow-2xl">
              {/* Chapter Header */}
              <div className="bg-gradient-to-r from-emerald-600/30 to-blue-600/30 border-b border-emerald-400/20 p-8">
                <h1 className="text-4xl font-black text-white mb-2">{chapterContent?.title}</h1>
                <p className="text-emerald-300">Chapter {chapterContent?.chapterNumber}</p>
              </div>

              {/* Tabs */}
              <div className="flex overflow-x-auto border-b border-emerald-400/20 bg-slate-800/50">
                {[
                  { id: 'notes', label: '📜 Notes' },
                  { id: 'timeline', label: '📅 Timeline' },
